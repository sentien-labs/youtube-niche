# Copy to .env and fill in. The tool loads .env automatically (and never overrides
# variables already exported in your shell).

# --- YouTube auth: provide EITHER an API key OR OAuth files (API key wins if both set) ---

# Option 1: a YouTube Data API v3 key from a Google Cloud project. Simplest.
YOUTUBE_API_KEY=your-youtube-data-api-v3-key

# Option 2: OAuth credentials (used automatically when YOUTUBE_API_KEY is unset and both
# files exist). Use absolute paths on your machine.
# YOUTUBE_OAUTH_CLIENT_SECRET=/absolute/path/to/client_secret.json
# YOUTUBE_OAUTH_TOKEN=/absolute/path/to/token.json

# Required for the LLM signals (comment-demand mining + content-depth scoring).
# If absent, the tool still runs, but confidence is lower because those signals are missing.
ANTHROPIC_API_KEY=your-anthropic-key

# Optional measurement defaults
# YOUTUBE_REGION_CODE=US
# YOUTUBE_RELEVANCE_LANGUAGE=en
# TRENDS_GEO=US
# YOUTUBE_DAILY_SEARCH_LIMIT=100
# QUERY_SAMPLES=1  # set to 3 for stricter multi-query niche validation
# KEYWORD_METRICS_CSV=/absolute/path/to/keyword-metrics.csv
# CACHE_ONLY=false  # true = only reuse cached YouTube API responses; never spend quota
